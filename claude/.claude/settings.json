{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "2"
  },
  "extraKnownMarketplaces": {
    "visual-explainer-marketplace": {
      "source": {
        "repo": "nicobailon/visual-explainer",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754063086050
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/claude-hook-handler.mjs",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/set-title-status.sh alert",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/claude-hook-handler.mjs",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/set-title-status.sh done",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/set-title-status.sh run",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git fetch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git grep:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git rev-parse:*)",
      "Bash(git reflog:*)",
      "Bash(git describe:*)",
      "Bash(git shortlog:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git cat-file:*)",
      "Bash(git worktree list:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git config -l:*)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh release download *)",
      "Bash(gh search *)",
      "Bash(gh status *)",
      "Bash(gh label list *)",
      "Bash(gh variable list *)",
      "Bash(gh secret list *)",
      "Bash(gh project list *)",
      "Bash(gh project view *)",
      "Bash(gh project field-list *)",
      "Bash(gh project item-list *)",
      "Bash(gh org list *)",
      "Bash(gh auth status *)",
      "Bash(gh config get *)",
      "Bash(gh config list *)",
      "Bash(gh extension list *)",
      "Bash(gh cache list *)",
      "Bash(glab mr view *)",
      "Bash(glab mr list *)",
      "Bash(glab mr diff *)",
      "Bash(glab issue view *)",
      "Bash(glab issue list *)",
      "Bash(glab ci view *)",
      "Bash(glab ci list *)",
      "Bash(glab ci status *)",
      "Bash(glab ci trace *)",
      "Bash(glab ci job *)",
      "Bash(glab job view *)",
      "Bash(glab repo view *)",
      "Bash(glab repo list *)",
      "Bash(glab search *)",
      "Bash(glab user *)",
      "Bash(glab auth status *)",
      "Bash(glab version)",
      "WebFetch"
    ],
    "defaultMode": "acceptEdits",
    "deny": []
  },
  "sandbox": {
    "excludedCommands": [
      "git commit",
      "git tag"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.cache/node/corepack/",
        "~/Library/pnpm/"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "syntaxHighlightingDisabled": false,
  "theme": "custom:kang8",
  "tui": "fullscreen"
}
