{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "2"
  },
  "extraKnownMarketplaces": {
    "visual-explainer-marketplace": {
      "source": {
        "repo": "nicobailon/visual-explainer",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754063086050
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/claude-hook-handler.mjs",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/set-title-status.sh alert",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/claude-hook-handler.mjs",
            "type": "command"
          },
          {
            "command": "bash ~/.claude/set-title-status.sh done",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/set-title-status.sh run",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git status:*)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(glab mr view *)",
      "Bash(glab mr list *)",
      "Bash(glab mr diff *)",
      "Bash(glab issue view *)",
      "Bash(glab issue list *)",
      "Bash(glab ci view *)",
      "Bash(glab ci list *)",
      "Bash(glab ci status *)",
      "Bash(glab ci trace *)",
      "Bash(glab ci job *)",
      "Bash(glab job view *)",
      "Bash(glab repo view *)",
      "Bash(glab repo list *)",
      "Bash(glab search *)",
      "Bash(glab user *)",
      "Bash(glab auth status *)",
      "Bash(glab version)",
      "WebFetch"
    ],
    "defaultMode": "acceptEdits",
    "deny": []
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.cache/node/corepack/",
        "~/Library/pnpm/"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "syntaxHighlightingDisabled": false,
  "theme": "custom:kang8",
  "tui": "fullscreen"
}
